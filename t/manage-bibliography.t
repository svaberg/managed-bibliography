use strict;
use warnings;

use Cwd qw(getcwd);
use FindBin qw($Bin);
use File::Spec;
use File::Temp qw(tempdir);
use Test::More;

my $script = File::Spec->catfile($Bin, '..', 'managed-bibliography.pl');
my $rv = do $script;
die $@ if $@;
die "could not load $script: $!" if !defined $rv;


sub write_file {
    my ($path, $content) = @_;
    open my $fh, '>', $path or die "open $path: $!";
    print {$fh} $content;
    close $fh or die "close $path: $!";
}


sub read_file {
    my ($path) = @_;
    open my $fh, '<', $path or die "open $path: $!";
    local $/ = undef;
    my $content = <$fh>;
    close $fh or die "close $path: $!";
    return $content;
}


sub managed_bib_with_header {
    my ($entries) = @_;
    my $header = <<'EOF';
% Managed bibliography file generated by managed-bibliography.pl.
% This file is maintained automatically from ADS lookups.
% Manual edits may be overwritten.
EOF

    return $header if !defined $entries || $entries eq '';
    return $header . "\n" . $entries;
}


sub capture_stdout {
    my ($code) = @_;
    my $output = '';
    open my $fh, '>', \$output or die "open scalar stdout: $!";
    local *STDOUT = $fh;
    my $result = $code->();
    return ($result, $output);
}


sub run_in_dir {
    my ($dir, $code) = @_;
    my $cwd = getcwd();
    chdir $dir or die "chdir $dir: $!";
    my @result = eval { $code->() };
    my $error = $@;
    chdir $cwd or die "chdir $cwd: $!";
    die $error if $error;
    return @result;
}


{
    package LocalHTTPClient;

    sub new {
        my ($class, %args) = @_;
        return bless \%args, $class;
    }

    sub get {
        my ($self, $url) = @_;
        push @{$self->{seen_urls}}, $url;
        return $self->{get_response};
    }
}


subtest 'ADS token discovery follows adstex-style lookup order' => sub {
    my $tmpdir = tempdir(CLEANUP => 1);
    my $adsdir = File::Spec->catdir($tmpdir, '.ads');
    mkdir $adsdir or die "mkdir $adsdir: $!";

    write_file(File::Spec->catfile($adsdir, 'token'), "file-token\n");
    write_file(File::Spec->catfile($adsdir, 'dev_key'), "file-dev-token\n");

    local $ENV{HOME} = $tmpdir;
    local $ENV{USERPROFILE};
    local $ENV{HOMEDRIVE};
    local $ENV{HOMEPATH};
    local $ENV{ADS_API_TOKEN};
    local $ENV{ADS_DEV_KEY};
    no warnings 'once';
    local $main::ads_api_token = 'rc-token';

    is(main::discover_ads_api_token(), 'file-token', 'file token is used before the latexmkrc setting');

    local $ENV{ADS_DEV_KEY} = 'env-dev-token';
    is(main::discover_ads_api_token(), 'env-dev-token', 'ADS_DEV_KEY is used before token files');

    local $ENV{ADS_API_TOKEN} = 'env-api-token';
    is(main::discover_ads_api_token(), 'env-api-token', 'ADS_API_TOKEN has highest priority');
};


subtest 'ADS identifier search canonicalizes alternate keys' => sub {
    my $http = LocalHTTPClient->new(
        get_response => {
            success => 1,
            content => <<'EOF',
{"response":{"docs":[
  {"bibcode":"2009LanB...4B..712L","identifier":["2009LanB...4B...44L","2009LanB...4B..712L"]},
  {"bibcode":"2020NaMet..17..261V","identifier":["2020NatMe..17..261V","2020NaMet..17..261V"]}
]}}
EOF
        },
        seen_urls => [],
    );

    my ($status, $resolved, $detail) = ManagedBibliography::resolve_ads_bibcodes(
        [qw(2009LanB...4B...44L 2020NatMe..17..261V)],
        ads_api_token => 'token',
        http_client => $http,
    );

    is($status, 'ok', 'identifier resolution succeeds');
    is($detail, undef, 'no extra detail is returned on success');
    is_deeply(
        $resolved,
        {
            '2009LanB...4B...44L' => '2009LanB...4B..712L',
            '2020NatMe..17..261V' => '2020NaMet..17..261V',
        },
        'alternate identifiers are mapped to canonical bibcodes',
    );
    like(
        $http->{seen_urls}[0],
        qr/identifier%3A%222009LanB\.\.\.4B\.\.\.44L%22/,
        'identifier search is sent to ADS',
    );
};


subtest 'local bibliography plus missing ADS key without token' => sub {
    my $tmpdir = tempdir(CLEANUP => 1);

    write_file(
        File::Spec->catfile($tmpdir, 'paper.aux'),
        <<'EOF'
\relax
\bibdata{paper.adskeys,custom}
\citation{localkey,missingkey}
EOF
    );

    write_file(
        File::Spec->catfile($tmpdir, 'custom.bib'),
        <<'EOF'
@article{localkey,
  title = {Local},
}
EOF
    );

    my ($rc, $stdout) = run_in_dir(
        $tmpdir,
        sub {
            return capture_stdout(
                sub {
                    ManagedBibliography::manage_bibliography(
                        document_base => 'paper',
                    );
                }
            );
        }
    );

    is($rc, 0, 'manage_bibliography returns success without token');
    like($stdout, qr/ADS API token unavailable/, 'missing token is reported');
    is(
        read_file(File::Spec->catfile($tmpdir, 'paper.adskeys.bib')),
        managed_bib_with_header(''),
        'managed bibliography keeps only its header when nothing can be fetched',
    );
    ok(!-e File::Spec->catfile($tmpdir, 'paper.keys.tex'), 'no citation key cache file is created');
};


