subtest 'rewrite preserves ADS-style escaped entries and replaces updated keys' => sub {
    my $tmpdir = tempdir(CLEANUP => 1);
    my $managed_bib_path = File::Spec->catfile($tmpdir, 'paper.adskeys.bib');

    write_file(
        $managed_bib_path,
        managed_bib_with_header(<<'EOF'),
@ARTICLE{1958ZA.....46..108B,
  author = {{B{\"o}hm-Vitense}, E.},
  title = "{{\"U}ber die Wasserstoffkonvektionszone}",
}

@ARTICLE{2002Sci...295...82K,
  title = {Original},
}
EOF
    );

    capture_stdout(
        sub {
            ManagedBibliography::append_bibliography_entries(
                $managed_bib_path,
                <<'EOF'
@ARTICLE{2002Sci...295...82K,
  title = {Replacement},
}
EOF
            );
        }
    );

    is(
        read_file($managed_bib_path),
        managed_bib_with_header(<<'EOF'),
@ARTICLE{1958ZA.....46..108B,
  author = {{B{\"o}hm-Vitense}, E.},
  title = "{{\"U}ber die Wasserstoffkonvektionszone}",
}

@ARTICLE{2002Sci...295...82K,
  title = {Replacement},
}
EOF
        'rewrite keeps ADS-style escaped entries and replaces by key without duplicates',
    );
};


