subtest 'canonicalized ADS lookups preserve the cited key in the managed bibliography' => sub {
    my $tmpdir = tempdir(CLEANUP => 1);

    write_file(
        File::Spec->catfile($tmpdir, 'paper.aux'),
        <<'EOF'
\relax
\bibdata{paper.adskeys}
\citation{2009LanB...4B...44L,2020NaMet..17..261V}
EOF
    );

    my @exported;
    my ($rc, $stdout) = run_in_dir(
        $tmpdir,
        sub {
            no warnings 'redefine';
            local *ManagedBibliography::resolve_ads_bibcodes = sub {
                return (
                    'ok',
                    {
                        '2009LanB...4B...44L' => '2009LanB...4B..712L',
                        '2020NaMet..17..261V' => '2020NaMet..17..261V',
                    },
                    undef,
                );
            };
            local *ManagedBibliography::fetch_ads_bibtex_entries = sub {
                my ($keys_ref) = @_;
                push @exported, @{$keys_ref};
                return (
                    'ok',
                    <<'EOF'
@article{2009LanB...4B..712L,
  title = {Lodders},
}

@article{2020NaMet..17..261V,
  title = {SciPy},
}
EOF
                    ,
                    {},
                );
            };
            return capture_stdout(
                sub {
                    ManagedBibliography::manage_bibliography(
                        document_base => 'paper',
                        ads_api_token => 'token',
                    );
                }
            );
        }
    );

    is($rc, 0, 'manage_bibliography returns success after canonicalized lookup');
    is_deeply(
        [sort @exported],
        [qw(2009LanB...4B..712L 2020NaMet..17..261V)],
        'only canonical bibcodes are exported',
    );
    like($stdout, qr/ADS canonicalized <2009LanB\.\.\.4B\.\.\.44L> => <2009LanB\.\.\.4B\.\.712L>/, 'canonicalization is reported');
    like($stdout, qr/ADS returned entry for <2009LanB\.\.\.4B\.\.\.44L>/, 'alternate cited key is marked as resolved');
    like($stdout, qr/ADS returned entry for <2020NaMet\.\.17\.\.261V>/, 'canonical cited key is marked as resolved');
    is(
        read_file(File::Spec->catfile($tmpdir, 'paper.adskeys.bib')),
        managed_bib_with_header(<<'EOF'),
@article{2009LanB...4B...44L,
  title = {Lodders},
}

@article{2020NaMet..17..261V,
  title = {SciPy},
}
EOF
        'managed bibliography preserves cited keys after canonicalized ADS lookup',
    );
};


subtest 'fetches only unresolved keys and appends returned entries' => sub {
    my $tmpdir = tempdir(CLEANUP => 1);

    write_file(
        File::Spec->catfile($tmpdir, 'paper.aux'),
        <<'EOF'
\relax
\bibdata{paper.adskeys,custom}
\citation{existingkey,localkey,newkey,missingkey}
EOF
    );

    write_file(
        File::Spec->catfile($tmpdir, 'paper.adskeys.bib'),
        <<'EOF'
@article{existingkey,
  title = {Existing},
}
EOF
    );

    write_file(
        File::Spec->catfile($tmpdir, 'custom.bib'),
        <<'EOF'
@article{localkey,
  title = {Local},
}
EOF
    );

    my @fetched;
    my ($rc, $stdout) = run_in_dir(
        $tmpdir,
        sub {
            no warnings 'redefine';
            local *ManagedBibliography::resolve_ads_bibcodes = sub {
                my ($keys_ref) = @_;
                return (
                    'ok',
                    { map { $_ => $_ } @{$keys_ref} },
                    undef,
                );
            };
            local *ManagedBibliography::fetch_ads_bibtex_entries = sub {
                my ($keys_ref) = @_;
                push @fetched, @{$keys_ref};
                return (
                    'ok',
                    <<'EOF'
@article{newkey,
  title = {Fetched},
}
EOF
                    ,
                    {
                        newkey => 1,
                    },
                );
            };
            return capture_stdout(
                sub {
                    ManagedBibliography::manage_bibliography(
                        document_base => 'paper',
                        ads_api_token => 'token',
                    );
                }
            );
        }
    );

    is($rc, 0, 'manage_bibliography returns success with stubbed ADS export');
    is_deeply(
        [sort @fetched],
        [qw(missingkey newkey)],
        'only unresolved keys are sent to ADS',
    );
    like($stdout, qr/ADS returned entry for <newkey>/, 'fetch success is reported');
    like($stdout, qr/ADS returned no entry for <missingkey>/, 'fetch miss is reported');

    my $managed_bib = read_file(File::Spec->catfile($tmpdir, 'paper.adskeys.bib'));
    like($managed_bib, qr/^% Managed bibliography file generated by managed-bibliography\.pl\./, 'managed bibliography header is written');
    like($managed_bib, qr/\@article\{existingkey,/, 'existing managed entry remains');
    like($managed_bib, qr/\@article\{newkey,/, 'fetched entry is appended');
    ok(!-e File::Spec->catfile($tmpdir, 'paper.keys.tex'), 'no citation key cache file is created after fetch');
};


subtest 'managed bibliography is rewritten sorted by key' => sub {
    my $tmpdir = tempdir(CLEANUP => 1);

    write_file(
        File::Spec->catfile($tmpdir, 'paper.aux'),
        <<'EOF'
\relax
\bibdata{paper.adskeys}
\citation{akey,mkey,zkey}
EOF
    );

    write_file(
        File::Spec->catfile($tmpdir, 'paper.adskeys.bib'),
        <<'EOF'
@article{zkey,
  title = {Existing},
}
EOF
    );

    my ($rc, $stdout) = run_in_dir(
        $tmpdir,
        sub {
            no warnings 'redefine';
            local *ManagedBibliography::resolve_ads_bibcodes = sub {
                my ($keys_ref) = @_;
                return (
                    'ok',
                    { map { $_ => $_ } @{$keys_ref} },
                    undef,
                );
            };
            local *ManagedBibliography::fetch_ads_bibtex_entries = sub {
                return (
                    'ok',
                    <<'EOF'
@article{mkey,
  title = {Middle},
}

@article{akey,
  title = {First},
}
EOF
                    ,
                    {
                        akey => 1,
                        mkey => 1,
                    },
                );
            };
            return capture_stdout(
                sub {
                    ManagedBibliography::manage_bibliography(
                        document_base => 'paper',
                        ads_api_token => 'token',
