        }
    );

    is($rc, 0, 'manage_bibliography returns success for sorted rewrite');
    like($stdout, qr/Writing 3 ADS entries to paper\.adskeys\.bib/, 'write message reports the number of managed entries');
    is(
        read_file(File::Spec->catfile($tmpdir, 'paper.adskeys.bib')),
        managed_bib_with_header(<<'EOF'),
@article{akey,
  title = {First},
}

@article{mkey,
  title = {Middle},
}

@article{zkey,
  title = {Existing},
