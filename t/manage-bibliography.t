subtest 'authentication failure is reported clearly and stops ADS retries' => sub {
    my $tmpdir = tempdir(CLEANUP => 1);

    write_file(
        File::Spec->catfile($tmpdir, 'paper.aux'),
        <<'EOF'
\relax
\bibdata{paper.adskeys,custom}
\citation{authkey,otherkey}
EOF
    );

    write_file(
        File::Spec->catfile($tmpdir, 'custom.bib'),
        <<'EOF'
@article{localkey,
  title = {Local},
}
EOF
    );

    my @fetched;
    my ($rc, $stdout) = run_in_dir(
        $tmpdir,
        sub {
            no warnings 'redefine';
            local *ManagedBibliography::resolve_ads_bibcodes = sub {
                my ($keys_ref) = @_;
                return (
                    'ok',
                    { map { $_ => $_ } @{$keys_ref} },
                    undef,
                );
            };
            local *ManagedBibliography::fetch_ads_bibtex_entries = sub {
                my ($keys_ref) = @_;
                push @fetched, @{$keys_ref};
                return ('auth', undef, 401);
            };
            return capture_stdout(
                sub {
                    ManagedBibliography::manage_bibliography(
                        document_base => 'paper',
                        ads_api_token => 'bad-token',
                    );
                }
            );
        }
    );

    is($rc, 0, 'manage_bibliography returns success on auth failure');
    is_deeply(\@fetched, [qw(authkey otherkey)], 'bulk auth failure happens in one ADS attempt for all unresolved keys');
    like($stdout, qr/ADS authentication failed \(HTTP 401\)/, 'auth failure is reported clearly');
    unlike($stdout, qr/ADS lookup failed for <authkey>/, 'generic per-key failure message is not used for auth');
    is(
        read_file(File::Spec->catfile($tmpdir, 'paper.adskeys.bib')),
        managed_bib_with_header(''),
        'managed bibliography keeps only its header on auth failure',
    );
};


